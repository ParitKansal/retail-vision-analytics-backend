# Copy this file to .env and fill in real values before running docker-compose

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=your_strong_mongo_password

# MinIO object storage
MINIO_USER=minioadmin
MINIO_PASSWORD=your_strong_minio_password

# Cloud MongoDB destination (for db_sync_service)
# Format: mongodb+srv://user:pass@host/ or mongodb://user:pass@host:port/
MONGODB_DESTINATION=mongodb://user:password@your-cloud-host:27017/

# Camera credentials (used in stream_handling_service/settings.py)
CAMERA_USER=admin
CAMERA_PASS=your_camera_password
